<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>THE SOMA STUDIO | 課堂備註系統</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { cream: '#F5F0E8', burgundy: '#5B2333', dark: '#2C1E16', gold: '#C8A97E' }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Noto Sans TC', sans-serif; background-color: #F5F0E8; color: #2C1E16; }
        .glass-card { background: rgba(255,255,255,0.8); backdrop-filter: blur(10px); border: 1px solid rgba(91,35,51,0.1); box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body class="antialiased pb-10">

    <nav class="sticky top-0 w-full bg-burgundy text-cream shadow-md z-50">
        <div class="px-5 py-4 flex justify-between items-center">
            <h1 class="text-lg font-bold tracking-widest">課堂學員備註</h1>
            <iconify-icon icon="ph:notebook-light" class="text-2xl"></iconify-icon>
        </div>
    </nav>

    <div id="loading" class="flex flex-col items-center justify-center h-[70vh]">
        <iconify-icon icon="eos-icons:loading" class="text-4xl text-burgundy mb-2"></iconify-icon>
        <p class="text-sm tracking-widest text-dark/60">正在讀取名單...</p>
    </div>

    <main id="content" class="px-4 py-6 max-w-lg mx-auto hidden">
        <div class="mb-6 border-b border-burgundy/20 pb-4">
            <h2 id="course-name" class="text-xl font-bold text-burgundy mb-2">課程名稱</h2>
            <div class="flex flex-wrap items-center gap-3 text-xs text-dark/60 font-mono tracking-wide">
                <span class="flex items-center gap-1"><iconify-icon icon="ph:clock"></iconify-icon> <span id="course-time">時間</span></span>
                <span class="flex items-center gap-1 bg-white/60 px-2 py-0.5 rounded-full border border-burgundy/10 shadow-sm"><iconify-icon icon="ph:map-pin"></iconify-icon> <span id="course-loc">地點</span></span>
            </div>
        </div>

        <div id="students-container" class="space-y-4">
            <!-- 學生卡片將會注入在這裡 -->
        </div>
    </main>

    <!-- Toast -->
    <div id="toast" class="fixed bottom-6 left-1/2 transform -translate-x-1/2 bg-dark text-cream px-5 py-2.5 rounded-full shadow-xl transition-all duration-300 opacity-0 translate-y-4 pointer-events-none z-[999] text-xs tracking-wider"></div>

    <script>
        // ★ 核心修正：直接從範本標籤中讀取變數，不再依賴 window.location.search
        const instId = '<?= typeof instId !== "undefined" ? instId : "" ?>';
        const tp = '<?= typeof tp !== "undefined" ? tp : "" ?>';
        
        var toastTimeout;

        function showMsg(msg) {
            var toast = document.getElementById('toast');
            toast.innerText = msg;
            toast.classList.remove('opacity-0', 'translate-y-4');
            clearTimeout(toastTimeout);
            toastTimeout = setTimeout(function() {
                toast.classList.add('opacity-0', 'translate-y-4');
            }, 3000);
        }

        window.onload = function() {
            // 驗證參數是否成功「餵」進來
            if (!instId || !tp) {
                document.getElementById('loading').innerHTML = `
                    <div class="text-center p-8 bg-red-50 rounded-2xl border border-red-200">
                        <iconify-icon icon="ph:warning-circle-bold" class="text-4xl text-red-500 mb-2"></iconify-icon>
                        <p class="text-red-700 font-bold">無效的連結參數</p>
                        <p class="text-xs text-red-500/70 mt-2">請確保從 LINE 推播訊息點擊進入</p>
                    </div>`;
                return;
            }

            if (typeof google !== 'undefined') {
                google.script.run.withSuccessHandler(function(res) {
                    document.getElementById('loading').classList.add('hidden');
                    if (res.success) {
                        renderPage(res);
                    } else {
                        document.getElementById('content').innerHTML = `
                            <div class="text-center p-8 bg-white rounded-2xl border border-burgundy/10 mt-10">
                                <iconify-icon icon="ph:lock-key-bold" class="text-4xl text-burgundy mb-2"></iconify-icon>
                                <p class="text-burgundy font-bold">${res.msg}</p>
                            </div>`;
                        document.getElementById('content').classList.remove('hidden');
                    }
                }).withFailureHandler(function(err) {
                    document.getElementById('loading').innerHTML = '<p class="text-red-600 font-bold">連線失敗，請重新整理</p>';
                }).getTeacherNotesData(instId, tp);
            }
        };

        function renderPage(data) {
            document.getElementById('course-name').innerText = data.courseName;
            document.getElementById('course-time').innerText = data.timeInfo;
            document.getElementById('course-loc').innerText = data.location || 'THE SOMA STUDIO';
            
            const container = document.getElementById('students-container');
            if (data.students.length === 0) {
                container.innerHTML = '<p class="text-center text-dark/50 text-sm mt-10">本堂課目前無人預約</p>';
                document.getElementById('content').classList.remove('hidden');
                return;
            }

            let html = '';
            data.students.forEach((st, idx) => {
                let badge = st.tier === '正式' ? '<span class="bg-gray-200 text-gray-600 px-1.5 rounded text-[10px]">正式</span>' : `<span class="bg-gold/20 text-burgundy px-1.5 rounded text-[10px] font-bold">${st.tier}</span>`;
                
                html += `
                <div class="glass-card rounded-2xl p-4 relative">
                    <div class="flex justify-between items-start mb-3 border-b border-gray-200 pb-2">
                        <div>
                            <div class="font-bold text-dark text-base flex items-center gap-1">${idx+1}. ${st.name} <span class="text-xs text-gray-500 font-normal">(${st.age}歲)</span> ${badge}</div>
                            <div class="text-[10px] text-gray-400 font-mono mt-0.5">📞 ${st.phone}</div>
                        </div>
                        <div class="text-right">
                            <div class="text-xs font-bold text-burgundy">餘 ${st.remainPoints} 點</div>
                            <div class="text-[9px] text-gray-500 mt-0.5">到期: ${st.expireDate}</div>
                        </div>
                    </div>
                    
                    <label class="block text-[10px] font-bold text-dark/70 mb-1">學員需求 / 課堂筆記：</label>
                    <textarea id="need_${st.phone}" class="w-full bg-white border border-gray-200 rounded-xl p-3 text-sm outline-none focus:border-burgundy focus:ring-1 focus:ring-burgundy/20 transition-all min-h-[80px]" placeholder="請輸入學員身體狀況或今日上課筆記...">${st.need}</textarea>
                    
                    <button onclick="saveNote(this, '${st.phone}')" class="w-full mt-2 bg-dark text-cream py-2.5 rounded-xl text-xs font-bold tracking-widest hover:bg-burgundy transition-colors flex justify-center items-center gap-1 active:scale-95 transition-transform">
                        <iconify-icon icon="ph:floppy-disk-back"></iconify-icon> 儲存備註
                    </button>
                </div>`;
            });

            container.innerHTML = html;
            document.getElementById('content').classList.remove('hidden');
        }

        function saveNote(btnEl, phone) {
            const textArea = document.getElementById('need_' + phone);
            const newNeed = textArea.value.trim();
            const originalText = btnEl.innerHTML;

            btnEl.innerHTML = '<iconify-icon icon="eos-icons:loading" class="text-sm"></iconify-icon> 儲存中...';
            btnEl.disabled = true;

            if (typeof google !== 'undefined') {
                google.script.run.withSuccessHandler(function(res) {
                    if (res.success) {
                        btnEl.innerHTML = '<iconify-icon icon="ph:check-circle"></iconify-icon> 已儲存';
                        btnEl.classList.remove('bg-dark');
                        btnEl.classList.add('bg-green-700');
                        showMsg('備註更新成功！');
                        setTimeout(() => { 
                            btnEl.innerHTML = originalText; 
                            btnEl.classList.remove('bg-green-700');
                            btnEl.classList.add('bg-dark');
                            btnEl.disabled = false; 
                        }, 2000);
                    } else {
                        alert(res.msg);
                        btnEl.innerHTML = originalText;
                        btnEl.disabled = false;
                    }
                }).withFailureHandler(function(err) {
                    alert('連線失敗，請檢查網路');
                    btnEl.innerHTML = originalText;
                    btnEl.disabled = false;
                }).saveStudentNeed(phone, newNeed);
            }
        }
    </script>
</body>
</html>
